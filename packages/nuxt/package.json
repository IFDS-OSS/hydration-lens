{
  "name": "@ifds-oss/hydration-lens-nuxt",
  "version": "0.1.0",
  "description": "Zero-config Nuxt module for hydration-lens: registers the Vue adapter as a dev-only client plugin.",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/IFDS-OSS/hydration-lens.git", "directory": "packages/nuxt" },
  "homepage": "https://github.com/IFDS-OSS/hydration-lens#readme",
  "bugs": { "url": "https://github.com/IFDS-OSS/hydration-lens/issues" },
  "type": "module",
  "main": "./dist/module.cjs",
  "module": "./dist/module.mjs",
  "types": "./dist/types.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "nuxt-module-build build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/kit": "^3.14.0",
    "@ifds-oss/hydration-lens-vue": "workspace:*"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^0.8.4",
    "@nuxt/schema": "^3.14.0",
    "nuxt": "^3.14.0",
    "typescript": "^5.7.2"
  }
}
